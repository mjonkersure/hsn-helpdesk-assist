# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# Claude Code local state (permissions cache, machine-specific)
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts

# private data (bevat klant-PII: namen, e-mails, telefoonnummers)
/src/data/private/

# sample-transcripten bevatten klantgesprekken met namen/adressen → niet in publieke repo.
# Lokaal genereren met scripts/extract-sample-transcripts.ps1
/src/data/sample-transcripts/

