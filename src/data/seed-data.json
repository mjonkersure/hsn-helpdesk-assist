  "driverDefs": {
    "welkom": "Begroet klant met tijd-van-dag, naam en organisatie in eerste 30 seconden.",
    "vraag_capteren": "Vat de klantvraag samen of herhaalt voor verificatie (\"als ik het goed begrijp...\").",
    "identificatie": "Vraagt klantgegevens uit: kenteken, e-mail, achternaam, VIN, chassisnummer.",
    "oplossing": "Benoemt concreet wat er gaat gebeuren (\"wat ik voor u ga doen is...\", \"ik ga regelen...\").",
    "toon": "Warme, dynamische toon, geen stiltes. Vereist audio-analyse — fase 2.",
    "empathie": "Erkent emotie (\"wat vervelend\") of geeft ruimte via vragende zinnen (\"waar kan ik u verder mee helpen?\").",
    "afsluiting": "Sluit af met bedankje, beleefdheidsformule, vervolgvraag.",
    "enquete": "Benoemt enquête-mogelijkheid actief, eventueel met \"9 of 10 helpt enorm\".",
    "inhoud": "Inhoudelijk juiste antwoord. Vereist Renault-KB — fase 2."
  },
